+    sing-box-1.13.13-linux-armv7.tar.gz)        echo 'bc267458391df9260e7d90f9aee8ff04a86d5039a870fdb853e3eef03bec96fc' ;;
+    sing-box-1.13.13-linux-armv7-glibc.tar.gz)  echo '6f9e2642b282ac1a554b5890247a5f4c05d8a33611cd26db654ed593fc957607' ;;
