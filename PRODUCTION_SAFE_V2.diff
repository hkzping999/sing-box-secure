+get_embedded_sha256() {
+  local ASSET="$1"
+  case "$ASSET" in
+    sing-box-1.13.13-linux-amd64.tar.gz)        echo 'd7d35b806db72ecfb3021a2148ab72f03e8af0baa5067a85d5573888574fd890' ;;
