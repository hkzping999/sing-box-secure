+}
+
+secure_download_with_sha256() {
+  local URL="$1" OUT="$2" ASSET="$3" EXPECTED
+  EXPECTED=$(get_embedded_sha256 "$ASSET") || error "\n Missing embedded SHA256 for $ASSET. Refusing to install. \n"
+  case "$URL" in
+    https://github.com/SagerNet/sing-box/releases/download/*|https://github.com/cloudflare/cloudflared/releases/download/*|https://github.com/jqlang/jq/releases/download/*) ;;
+    *) error "\n Unapproved binary download URL: $URL \n" ;;
+  esac
+  rm -f "$OUT"
+  if command -v wget >/dev/null 2>&1; then
+    wget --https-only --secure-protocol=TLSv1_2 --tries=3 --timeout=30 -qO "$OUT" "$URL" || error "\n Download failed: $ASSET \n"
+  elif command -v curl >/dev/null 2>&1; then
+    curl --proto '=https' --tlsv1.2 -fsSL --connect-timeout 15 --max-time 120 "$URL" -o "$OUT" || error "\n Download failed: $ASSET \n"
+  else
+    error "\n Neither wget nor curl is available. \n"
+  fi
+  echo "${EXPECTED}  ${OUT}" | sha256sum -c - >/dev/null 2>&1 || { rm -f "$OUT"; error "\n SHA256 verification failed for $ASSET. Installation aborted. \n"; }
+}
+
+secure_install_sing_box_to_temp() {
+  local ASSET="sing-box-${PINNED_SING_BOX_VERSION}-linux-${SING_BOX_ARCH}.tar.gz"
+  local ARCHIVE="${TEMP_DIR}/${ASSET}" SB_DIR="${TEMP_DIR}/sing-box-${PINNED_SING_BOX_VERSION}-linux-${SING_BOX_ARCH}"
+  secure_download_with_sha256 "https://github.com/SagerNet/sing-box/releases/download/v${PINNED_SING_BOX_VERSION}/${ASSET}" "$ARCHIVE" "$ASSET"
+  rm -rf "$SB_DIR" "$TEMP_DIR/sing-box"
+  tar xzf "$ARCHIVE" -C "$TEMP_DIR" "$SB_DIR/sing-box" 2>/dev/null || error "\n Failed to extract verified sing-box archive. \n"
+  [ -s "$SB_DIR/sing-box" ] || error "\n sing-box binary missing after extraction. \n"
+  mv "$SB_DIR/sing-box" "$TEMP_DIR/sing-box"
+  chmod +x "$TEMP_DIR/sing-box"
+}
+
+secure_install_jq_to_temp() {
+  local ASSET="jq-linux-${JQ_ARCH}"
+  secure_download_with_sha256 "https://github.com/jqlang/jq/releases/download/jq-${PINNED_JQ_VERSION}/${ASSET}" "$TEMP_DIR/jq" "$ASSET"
+  chmod +x "$TEMP_DIR/jq"
+}
+
+secure_install_cloudflared_to_temp() {
+  local ASSET="cloudflared-linux-${ARGO_ARCH}"
+  secure_download_with_sha256 "https://github.com/cloudflare/cloudflared/releases/download/${PINNED_CLOUDFLARED_VERSION}/${ASSET}" "$TEMP_DIR/cloudflared" "$ASSET"
+  chmod +x "$TEMP_DIR/cloudflared"
+}
