+# 安全版：生成并保存本机专用 WARP WireGuard 私钥，避免所有用户共用固定私钥
+secure_generate_warp_private_key() {
+  local key_file="${WORK_DIR}/warp_private_key"
+  mkdir -p "${WORK_DIR}" 2>/dev/null || true
+  if [ -s "$key_file" ]; then
+    cat "$key_file"
+    return 0
+  fi
+  umask 077
+  openssl rand 32 | base64 | tr -d '\n' > "$key_file"
+  chmod 600 "$key_file" 2>/dev/null || true
+  cat "$key_file"
+}
